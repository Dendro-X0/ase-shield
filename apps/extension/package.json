{
  "name": "@ase/extension",
  "version": "1.0.0-beta.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "build:firefox": "vite build && node ./scripts/prepare-firefox.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint -c ../../eslint.config.js src manifest.config.ts vite.config.ts"
  },
  "dependencies": {
    "@ase/core": "workspace:*",
    "@ase/rules": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.313",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
